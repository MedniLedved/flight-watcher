# Hlavní zdroj cen je Google Flights (scraping přes fast-flights) – NEPOTŘEBUJE
# žádný klíč. Volitelný režim stahování: common (přímý GET, výchozí) nebo
# fallback (při neúspěchu zkusí externí playwright službu try.playwright.tech).
# GOOGLEFLIGHTS_FETCH_MODE=common

# Duffel API – ZDROJ JE VYPNUTÝ v config/agent.json (live účet není zdarma).
# Token je potřeba jen při znovuzapnutí; musí být produkční duffel_live_...
# (duffel_test_... vrací SYNTETICKÁ data se smyšlenými cenami – scanner ho
# odmítne, smyšlené ceny by znehodnotily alerty i historii).
DUFFEL_TOKEN=

# Sky Scrapper přes RapidAPI – Skyscanner data, https://rapidapi.com/apiheya/api/sky-scrapper
# POZOR: free tier pouze 100 requestů/MĚSÍC – používej úsporně.
RAPIDAPI_KEY=your_rapidapi_key_here

# Amadeus – registrace na developers.amadeus.com
AMADEUS_CLIENT_ID=your_client_id
AMADEUS_CLIENT_SECRET=your_client_secret
# ⚠️ test = SYNTETICKÁ data (test.api.amadeus.com) – scanner zdroj v test
# režimu VYPNE. Pro reálné ceny nastav production (api.amadeus.com, stejný
# klíč po aktivaci produkce v dashboardu).
AMADEUS_ENV=production

# Travelpayouts – registrace na travelpayouts.com
TRAVELPAYOUTS_TOKEN=your_token_here

# Telegram – vytvoř bota přes @BotFather, chat_id zjisti přes @userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Volitelné
PRICE_THRESHOLD_EUR=550
LOG_LEVEL=INFO
CZK_EUR_RATE=25

# Miles & More mileage bargains (kontrola jen 1. v měsíci)
# Data se berou ze strukturovaného GraphQL endpointu webu M&M – endpoint i
# veřejný x-api-key jsou vestavěné, NORMÁLNĚ NIC NENASTAVUJEŠ.
# Přepsat lze jen při změně (jinak nech prázdné):
MILESANDMORE_API_URL=
MILESANDMORE_API_KEY=
# Volitelné hlavičky jako JSON, jen kdyby endpoint vyžadoval session (Cookie):
# např. {"Cookie": "..."}
MILESANDMORE_HEADERS=
# Opt-in: ignorovat robots.txt u fallback HTML scrapingu. Výchozí false.
MILESANDMORE_IGNORE_ROBOTS=false
